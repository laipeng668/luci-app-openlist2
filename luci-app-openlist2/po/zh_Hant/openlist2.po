msgstr "全域性設定"

#: luci-app-openlist2/root/usr/share/luci/menu.d/luci-app-openlist2.json:13
msgid "Setting"
msgstr "設定"

#: luci-app-openlist2/root/usr/share/luci/menu.d/luci-app-openlist2.json:21
#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:209
msgid "Logs"
