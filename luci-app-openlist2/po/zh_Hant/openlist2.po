#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:43
msgid "RUNNING"
msgstr "執行中"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:43
msgid "NOT RUNNING"
msgstr "未執行"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:51
msgid "Open Web Interface"
msgstr "開啟 Web 介面"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:100
msgid "Port must be -1 or a valid port number from 1 to 65535."
msgstr "埠必須為 -1，或 1 到 65535 之間的有效埠號。"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:120
msgid "Site URL must start with http:// or https:// and must not end with /."
msgstr "站點 URL 必須以 http:// 或 https:// 開頭，且末尾不能帶 /。"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:132
msgid "CORS origins must be * or include http:// or https://."
msgstr "CORS 來源必須為 *，或包含 http:// / https://。"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:170
msgid "Username:"
msgstr "使用者名稱："

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:170
msgid "New Password:"
msgstr "新密碼："

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:170
msgid "New password has been copied to clipboard."
msgstr "新密碼已複製到剪貼簿。"

#: luci-app-openlist2/root/usr/share/luci/menu.d/luci-app-openlist2.json:3
#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:183
msgid "OpenList"
msgstr "OpenList"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:184
msgid "A file list program that supports multiple storage."
msgstr "一款支援多種儲存的目錄檔案列表程式。"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:185
#, javascript-format
msgid ""
"Initial login username is \"%s\" and password is \"%s\". Change it "
"immediately after first login."
msgstr "初始登入使用者名稱為「%s」，密碼為「%s」。首次登入後請立即修改。"

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:201
msgid "Collecting data..."
msgstr "收集資料..."

#: luci-app-openlist2/htdocs/luci-static/resources/view/openlist2/basic.js:207
msgid "Basic Settings"
msgstr "基本設定"

