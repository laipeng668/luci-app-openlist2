{
	"luci-app-openlist2": {
		"description": "Grant UCI access for luci-app-openlist2",
		"read": {
			"file": {
				"/usr/bin/openlist2": [ "exec" ],
				"/var/log/openlist2.log": [ "read" ],
				"/var/log/openlist2*": [ "read" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "openlist2" ]
		},
		"write": {
			"file": {
				"/var/log/openlist2.log": [ "write" ],
				"/var/log/openlist2*": [ "write" ]
			},
			"uci": [ "openlist2" ]
		}
	}
}
