
config openlist2
	option enabled '0'
	option debug '0'
	option delayed_start '0'
	option allow_wan '0'
	option force '1'
	option token_expires_in '48'
	option proxy_address ''
	option auto_memory_limit '4'
	option min_free_memory '0'
	option max_block_limit '0'
	option max_connections '0'
	option max_concurrency '64'
	option tls_insecure_skip_verify '0'
	option data_dir '/etc/openlist2'
	option temp_dir '/tmp/openlist2'
	option log '1'
	option log_path '/var/log/openlist2.log'
	option log_max_size '50'
	option log_max_backups '30'
	option log_max_age '28'
	option log_compress '0'
	option log_filter '0'
	option log_filter_cidr ''
	option log_filter_path ''
	option log_filter_method ''
	option database_type 'sqlite3'
	option meilisearch_host 'http://localhost:7700'
	option meilisearch_api_key ''
	option meilisearch_index 'openlist'
	option listen_addr '0.0.0.0'
	option listen_http_port '5244'
	option listen_https_port '-1'
	option listen_unix_file ''
	option listen_unix_file_perm ''
	option listen_enable_h2c '0'
	option listen_enable_h3 '0'
	option download_workers '5'
	option download_max_retry '1'
	option download_task_persistant '0'
	option transfer_workers '5'
	option transfer_max_retry '2'
	option transfer_task_persistant '0'
	option upload_workers '5'
	option upload_max_retry '0'
	option upload_task_persistant '0'
	option copy_workers '5'
	option copy_max_retry '2'
	option copy_task_persistant '0'
	option move_workers '5'
	option move_max_retry '2'
	option move_task_persistant '0'
	option decompress_workers '5'
	option decompress_max_retry '2'
	option decompress_task_persistant '0'
	option decompress_upload_workers '5'
	option decompress_upload_max_retry '2'
	option decompress_upload_task_persistant '0'
	option allow_retry_canceled '0'
	option cors_allow_origins '*'
	option cors_allow_methods '*'
	option cors_allow_headers '*'
	option s3 '0'
	option s3_port '5246'
	option s3_ssl '0'
	option ftp '0'
	option ftp_port '5221'
	option find_pasv_port_attempts '50'
	option active_transfer_port_non_20 '0'
	option idle_timeout '900'
	option connection_timeout '30'
	option disable_active_mode '0'
	option default_transfer_binary '0'
	option enable_active_conn_ip_check '1'
	option enable_pasv_conn_ip_check '1'
	option sftp '0'
	option sftp_port '5222'
